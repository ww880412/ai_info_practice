generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────── Core Entity ───────────────

model Entry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Raw input
  inputType   InputType
  rawUrl      String?
  rawText     String?          @db.Text
  sourceType  SourceType
  title       String?
  originalContent String?      @db.Text

  // API credential for processing (optional, uses env default if null)
  credentialId String?

  // AI processing status
  processStatus ProcessStatus  @default(PENDING)
  processError  String?

  // Knowledge management status (B1.2)
  knowledgeStatus KnowledgeStatus @default(PENDING)
  reviewedAt      DateTime?
  archivedAt      DateTime?
  deprecatedReason String?

  // AI extracted metadata (B1.4)
  extractedMetadata Json?

  // L1 classification
  contentType   ContentType?
  techDomain    TechDomain?
  aiTags        String[]
  userTags      String[]

  // L2 extraction
  coreSummary   String?
  keyPoints     String[]
  practiceValue PracticeValue?

  // Dynamic summary (Phase 2)
  summaryStructure Json?   // { type, fields, reasoning }
  keyPointsNew    Json?   // { core: [], extended: [] } - 双写字段
  boundaries      Json?   // { applicable: [], notApplicable: [] }
  confidence      Float?  // 综合置信度

  // Evaluation dimensions
  difficulty      Difficulty?  // BEGINNER/INTERMEDIATE/ADVANCED/EXPERT
  contentForm     ContentForm? // TEXTUAL/CODE_HEAVY/VISUAL/MULTIMODAL
  timeliness      Timeliness?  // RECENT/OUTDATED/CLASSIC
  sourceTrust     TrustLevel? // HIGH/MEDIUM/LOW

  // Smart summary (V2 Task 2)
  smartSummary    String? @db.Text
  keyInsights     String[]
  tldr            String?
  qualityOverride Json?

  // L3 practice (1:1)
  practiceTask  PracticeTask?

  // Parse logs (1:many)
  parseLogs ParseLog[]

  // Reasoning traces (1:many)
  reasoningTraces ReasoningTrace[]

  // Original execution mode (for mode comparison baseline)
  originalExecutionMode String? // 'two-step' or 'tool-calling'

  // Quality revision history (1:many)
  qualityHistories QualityRevision[] @relation("EntryQualityHistory")

  // Process attempts (1:many)
  processAttempts ProcessAttempt[] @relation("EntryProcessAttempts")

  // Groups (many:many)
  groups Group[] @relation("EntryGroups")

  // New relations (B2.1)
  aiResults EntryAIResult[]
  evaluation EntryEvaluation?
  smartSummaryRelation EntrySmartSummary?
  notes EntryNote[]

  // Mode comparisons (1:many)
  modeComparisons ModeComparison[]

  @@index([processStatus])
  @@index([knowledgeStatus])
  @@index([knowledgeStatus, reviewedAt])
  @@index([contentType])
  @@index([techDomain])
  @@index([createdAt])
  @@index([updatedAt(sort: Desc)])
  @@index([confidence(sort: Desc)])
  @@index([practiceValue])
  @@index([difficulty])
  @@index([confidence, practiceValue, difficulty])
}

// Reasoning trace for ReAct agent
model ReasoningTrace {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  // Steps stored as JSON
  steps        String @db.Text

  // Final result from the agent
  finalResult  String @db.Text

  // Metadata about the trace
  metadata     String @db.Text

  @@index([entryId])
}

model ParseLog {
  id            String   @id @default(cuid())
  entryId       String
  strategy      String
  inputSize     Int
  outputSize    Int
  processingTime Int
  success       Boolean
  error         String?
  createdAt    DateTime @default(now())

  entry         Entry   @relation(fields: [entryId], references: [id])
}

model PracticeTask {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entryId String @unique
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  title         String
  summary       String         @db.Text
  status        PracticeStatus @default(QUEUED)
  prerequisites String[]
  difficulty    Difficulty
  estimatedTime String

  steps PracticeStep[]

  startedAt   DateTime?
  completedAt DateTime?

  @@index([status])
}

model PracticeStep {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practiceTaskId String
  practiceTask   PracticeTask @relation(fields: [practiceTaskId], references: [id], onDelete: Cascade)

  order       Int
  title       String
  description String     @db.Text
  status      StepStatus @default(PENDING)
  note        String?

  startedAt   DateTime?
  completedAt DateTime?

  @@index([practiceTaskId, order])
}

// ─────────────── Enums ───────────────

enum InputType {
  LINK
  PDF
  TEXT
}

enum SourceType {
  GITHUB
  WECHAT
  TWITTER
  WEBPAGE
  PDF
  TEXT
}

enum ProcessStatus {
  PENDING
  PARSING
  AI_PROCESSING
  DONE
  FAILED
  PARTIAL
}

enum ContentType {
  TUTORIAL
  TOOL_RECOMMENDATION
  TECH_PRINCIPLE
  CASE_STUDY
  OPINION
}

enum TechDomain {
  PROMPT_ENGINEERING
  AGENT
  RAG
  FINE_TUNING
  DEPLOYMENT
  OTHER
}

enum PracticeValue {
  KNOWLEDGE
  ACTIONABLE
}

enum PracticeStatus {
  QUEUED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum KnowledgeStatus {
  PENDING
  TO_REVIEW
  ACTIVE
  ARCHIVED
  DEPRECATED
}

enum ContentForm {
  TEXTUAL
  CODE_HEAVY
  VISUAL
  MULTIMODAL
}

enum Timeliness {
  RECENT
  OUTDATED
  CLASSIC
}

enum TrustLevel {
  HIGH
  MEDIUM
  LOW
}

enum AttemptStatus {
  SUCCESS
  FAILED
  RUNNING
}

enum ComparisonMode {
  TWO_STEP
  TOOL_CALLING
}

enum BatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────── Group ───────────────

model Group {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    Group?   @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Group[]  @relation("GroupHierarchy")
  entries   Entry[]  @relation("EntryGroups")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, parentId])
  @@index([parentId])
}

model QualityRevision {
  id             String   @id @default(cuid())
  entryId        String
  entry          Entry    @relation("EntryQualityHistory", fields: [entryId], references: [id], onDelete: Cascade)
  previousJson   Json
  newJson        Json
  overrideReason String?
  createdAt      DateTime @default(now())
  createdBy      String?

  @@index([entryId])
}

model ProcessAttempt {
  id                String          @id @default(cuid())
  entryId           String
  entry             Entry           @relation("EntryProcessAttempts", fields: [entryId], references: [id], onDelete: Cascade)
  attemptNumber     Int
  status            AttemptStatus
  startedAt         DateTime
  completedAt       DateTime?
  durationMs        Int?
  inputSummary      String?
  error             String?
  previousAttemptId String?         @unique
  previousAttempt   ProcessAttempt? @relation("AttemptChain", fields: [previousAttemptId], references: [id], onDelete: SetNull)
  nextAttempt       ProcessAttempt? @relation("AttemptChain")
  retryAfterMs      Int?
  createdAt         DateTime        @default(now())

  @@unique([entryId, attemptNumber])
  @@index([entryId])
  @@index([previousAttemptId])
}

// ─────────────── Agent Config ───────────────

model AgentConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  config    Json
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────── API Credentials ───────────────

model ApiCredential {
  id             String   @id @default(cuid())
  encryptedKey   String   @db.Text
  keyHint        String?  // Last 4 chars for display (e.g., "...abcd")
  provider       String   @default("gemini")  // "gemini" | "openai-compatible" | "crs"
  baseUrl        String?  // For openai-compatible providers (e.g., local proxy)
  model          String?
  isValid        Boolean  @default(true)
  lastUsedAt     DateTime?
  lastValidatedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // New fields for multi-provider management
  name            String?
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  validationError String?
  config          Json?

  @@unique([provider, name, isActive])
  @@index([isValid])
  @@index([provider, isActive, isDefault])
  @@index([provider, isDefault, createdAt])
}

// ─────────────── Entry Split Tables (B2.1) ───────────────

model EntryAIResult {
  id        String   @id @default(cuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  contentType       ContentType?
  techDomain        TechDomain?
  aiTags            String[]
  coreSummary       String?
  keyPoints         String[]
  practiceValue     PracticeValue?
  summaryStructure  Json?
  keyPointsNew      Json?
  boundaries        Json?
  confidence        Float?
  extractedMetadata Json?

  version   Int     @default(1)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entryId, version])
  @@index([entryId])
  @@index([entryId, isActive])
}

model EntryEvaluation {
  id        String   @id @default(cuid())
  entryId   String   @unique
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  difficulty      Difficulty?
  contentForm     ContentForm?
  timeliness      Timeliness?
  sourceTrust     TrustLevel?
  qualityOverride Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entryId])
}

model EntrySmartSummary {
  id        String   @id @default(cuid())
  entryId   String   @unique
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  smartSummary String? @db.Text
  keyInsights  String[]
  tldr         String?
  generatedAt  DateTime @default(now())

  @@index([entryId])
}

model EntryNote {
  id        String   @id @default(cuid())
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  content   String @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entryId])
}

// ─────────────── Mode Comparison (Phase 3b) ───────────────

// Mode comparison for A/B testing Agent modes
model ModeComparison {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Associated Entry
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)

  // Original mode info
  originalMode      String  // 'two-step' | 'tool-calling'
  originalDecision  Json    // NormalizedAgentIngestDecision
  originalScore     Json    // QualityEvaluation

  // Comparison mode info
  comparisonMode     String  // 'two-step' | 'tool-calling'
  comparisonDecision Json    // NormalizedAgentIngestDecision
  comparisonScore    Json    // QualityEvaluation

  // Comparison result
  winner            String?  // 'original' | 'comparison' | 'tie'
  scoreDiff         Float    // comparisonScore.overallScore - originalScore.overallScore

  // Batch info
  batchId           String
  batchIndex        Int

  @@index([entryId])
  @@index([batchId])
}

model ComparisonBatch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Comparison modes
  sourceMode  ComparisonMode  // Baseline mode
  targetMode  ComparisonMode  // Comparison mode

  entryCount  Int
  status      BatchStatus     @default(PENDING)
  progress    Int             @default(0)  // Percentage: 0-100
  processedCount Int          @default(0)  // Actual processed entries

  // Statistics
  winRate     Float?
  avgScoreDiff Float?
  stats       Json?

  @@index([status])
  @@index([createdAt, id])  // Composite index for stable sorting
}
